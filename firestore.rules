rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      return request.auth.token.email_verified == true;
    }

    // -------------------------------------------------------------------------
    // CATCH-ALL DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USER PROFILES
    // -------------------------------------------------------------------------
    match /users/{userId} {
      function isValidUser(data) {
        return data.uid == request.auth.uid 
          && data.email is string && data.email.size() <= 256
          && data.keys().hasAll(['uid', 'email', 'createdAt'])
          && data.keys().size() <= 10;
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().uid == existing().uid
        && incoming().email == existing().email
        && incoming().createdAt == existing().createdAt
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'isPremium']);
    }

    // -------------------------------------------------------------------------
    // ANALYSES HISTORY
    // -------------------------------------------------------------------------
    match /users/{userId}/analyses/{analysisId} {
      function isValidAnalysis(data) {
        return data.userId == userId
          && data.faceShape is string && data.faceShape.size() <= 50
          && data.symmetry is int && data.symmetry >= 0 && data.symmetry <= 100
          && data.keys().hasAll(['userId', 'faceShape', 'symmetry', 'createdAt'])
          && data.keys().size() <= 15;
      }

      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidAnalysis(incoming()) && incoming().createdAt == request.time;
      allow delete: if isOwner(userId);
    }
  }
}
